rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(resourceData) {
      return request.auth.uid == resourceData.ownerId;
    }

    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidCar(data) {
      return data.keys().hasAll(['brand', 'model', 'year', 'price', 'ownerId']) &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() <= 100 &&
             data.model is string && data.model.size() > 0 && data.model.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.year is number &&
             data.price is number && data.price >= 0;
    }

    match /cars/{carId} {
      // Anyone can read cars to list them
      allow read: if true;
      
      allow create: if isSignedIn() && isValidId(carId) && isValidCar(incoming());
      
      allow update: if isSignedIn() && isValidId(carId) && isValidCar(incoming()) && (
        (isOwner(existing()) && incoming().diff(existing()).affectedKeys().hasOnly(['brand', 'model', 'year', 'price', 'importation', 'condition', 'mileage', 'fuelType', 'transmission', 'image', 'description'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['reviews']) && incoming().reviews.size() <= 100)
      ) && incoming().ownerId == existing().ownerId;

      allow delete: if isSignedIn() && isValidId(carId) && isOwner(existing());
    }
  }
}
